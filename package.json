{
  "name": "pmptr",
  "version": "0.1.1",
  "description": "A minimal virtual teleprompter that lives as a transparent, always-on-top, click-through overlay.",
  "main": "src/main/main.js",
  "bin": {
    "pmptr": "bin/pmptr.js"
  },
  "files": [
    "bin/**/*",
    "src/**/*",
    "assets/**/*"
  ],
  "author": {
    "name": "Jatin Malik",
    "email": "jatinkrmalik@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jatinkrmalik/pmptr.git"
  },
  "bugs": {
    "url": "https://github.com/jatinkrmalik/pmptr/issues"
  },
  "homepage": "https://github.com/jatinkrmalik/pmptr",
  "scripts": {
    "start": "electron .",
    "lint": "eslint src/",
    "test": "npm run lint",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.pmptr.app",
    "productName": "pmptr",
    "directories": {
      "output": "dist"
    },
    "files": [
      "bin/**/*",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  },
  "peerDependencies": {
    "electron": "^31.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
